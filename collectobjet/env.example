# Copier vers .env (ne pas committer .env)
# Le backend charge ce fichier au démarrage (springboot3-dotenv).

# ── PostgreSQL (obligatoire si l’utilisateur a un mot de passe SCRAM) ──
# Utiliser au moins UNE des lignes mot de passe ci‑dessous (même valeur).
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/collectobjet
SPRING_DATASOURCE_USERNAME=collectobjet_app
SPRING_DATASOURCE_PASSWORD=change_moi

# Variante reconnue si tu préfères ces noms (équivalent pour le mot de passe) :
# POSTGRES_USER=collectobjet_app
# POSTGRES_PASSWORD=change_moi

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT (prod : chaîne longue et aléatoire, min. 32 caractères pour HS256)
JWT_SECRET=

# CORS : origines / motifs (séparés par des virgules). Ex. prod + previews Vercel :
# APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://trouv-togo.vercel.app,https://*.vercel.app
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Données de référence : src/main/resources/data.sql
